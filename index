const casesEl=document.getElementById('cases');
CASES.forEach((c,i)=>{
  const steps=c.steps.map(s=>`<li>${s}</li>`).join('');
  const el=document.createElement('div');
  el.className='case reveal';
  el.innerHTML=`
    <div class="case-head">
      <div class="case-num">${i+1}</div>
      <div class="case-title"><h3>${c.t}</h3><div class="sub">${c.sub}</div></div>
      <div class="case-toggle">+</div>
    </div>
    <div class="case-body"><div class="case-inner">
      <div class="case-sit">${c.sit}</div>
      <ol class="steps">${steps}</ol>
      <div class="case-result"><b>Where it landed</b>${c.result}</div>
    </div></div>`;
  el.querySelector('.case-head').addEventListener('click',()=>el.classList.toggle('open'));
  casesEl.appendChild(el);
});
document.querySelector('.case')?.classList.add('open');

/* ---------- Scroll reveal ---------- */
const io=new IntersectionObserver((entries)=>{
  entries.forEach((en,idx)=>{
    if(en.isIntersecting){
      en.target.style.animationDelay=(Math.min(idx,4)*0.08)+'s';
      en.target.classList.add('in');
      io.unobserve(en.target);
    }
  });
},{threshold:.12});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
</script>
